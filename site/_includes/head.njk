{# Voice Aura — Shared <head> Partial
   Requires `title` variable from front matter. #}

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title | default('Voice Aura') }}</title>
<link rel="icon" type="image/svg+xml" href="../assets/brand/logo-icon.svg">
{% if description %}<meta name="description" content="{{ description }}">{% endif %}

<!-- Google Fonts (IBM Plex family) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- Compiled Design System CSS -->
<link rel="stylesheet" href="../dist/css/voice-aura.css">
