{# Voice Aura — Shared Navbar Partial
   Include in any page: {% include "navbar.njk" %}
   Set `activeLink` in front matter to highlight the current nav item.
   Set `homeHref` in front matter to change the brand link target. #}

<header class="va-navbar va-navbar--sticky va-nav-morph">
  <div class="va-navbar-inner">
    <a href="{{ homeHref | default('pixel-perfect-demo.html') }}" class="va-navbar-brand" aria-label="Voice Aura Home">
      <span class="va-navbar-brand__logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 32 32" fill="none">
          <rect x="4" y="10" width="3" height="12" rx="1.5" fill="#1A1919"/>
          <rect x="10" y="6" width="3" height="20" rx="1.5" fill="#1A1919"/>
          <rect x="16" y="3" width="3" height="26" rx="1.5" fill="#1A1919"/>
          <rect x="22" y="8" width="3" height="16" rx="1.5" fill="#1A1919"/>
          <rect x="28" y="11" width="3" height="10" rx="1.5" fill="#1A1919"/>
        </svg>
      </span>
      <span class="va-navbar-brand__text">VOICE AURA</span>
    </a>

    <button class="va-navbar-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false">
      <span class="va-navbar-toggle__line"></span>
      <span class="va-navbar-toggle__line"></span>
      <span class="va-navbar-toggle__line"></span>
    </button>

    <div class="va-navbar-collapse">
      <nav class="va-navbar-nav" aria-label="Main Navigation">
        <a href="#features-api" class="va-navbar-link{% if activeLink == 'products' %} va-navbar-link--active{% endif %}">Products</a>
        <a href="#features-dubbing" class="va-navbar-link{% if activeLink == 'integrations' %} va-navbar-link--active{% endif %}">Integrations</a>
        <a href="components.html" class="va-navbar-link{% if activeLink == 'api' %} va-navbar-link--active{% endif %}">API</a>
        <a href="#pricing" class="va-navbar-link{% if activeLink == 'pricing' %} va-navbar-link--active{% endif %}">Pricing</a>
      </nav>

      <div class="va-navbar-actions">
        <a href="login-demo.html" class="va-navbar-btn--outlined">
          Log in
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="signup-demo.html" class="va-navbar-btn--filled">
          Sign up
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>
