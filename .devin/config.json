{
  "permissions": {
    "allow": [
      "Read(**)",
      "Exec(npm run build)",
      "Exec(npm run build:css)",
      "Exec(npm run build:min)",
      "Exec(npm run watch:css)",
      "Exec(npm install)",
      "Exec(git)",
      "Exec(ls)",
      "Exec(cat)",
      "Exec(sass --version)"
    ],
    "deny": [
      "Exec(rm -rf)",
      "Exec(sudo)"
    ]
  },
  "read_config_from": {
    "cursor": true,
    "windsurf": true,
    "claude": true
  }
}
