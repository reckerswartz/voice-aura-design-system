{
  "name": "voice-aura-design-system",
  "version": "1.0.0",
  "description": "A premium SaaS design system built on Bootstrap 5, inspired by the Voice Aura AI platform",
  "main": "dist/css/voice-aura.css",
  "bin": {
    "voice-aura-setup": "bin/setup.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:css": "sass scss/voice-aura.scss dist/css/voice-aura.css --style=expanded --source-map",
    "build:min": "sass scss/voice-aura.scss dist/css/voice-aura.min.css --style=compressed --no-source-map",
    "build": "npm run build:css && npm run build:min",
    "watch:css": "sass --watch scss/voice-aura.scss dist/css/voice-aura.css --style=expanded --source-map",
    "screenshots": "node bin/screenshot-capture.mjs",
    "screenshots:quick": "node bin/screenshot-capture.mjs --breakpoints fhd,md,xs --skip-devices --concurrency 4 --pages-parallel 3",
    "screenshots:upload": "node bin/screenshot-upload.mjs",
    "screenshots:all": "npm run screenshots && npm run screenshots:upload"
  },
  "keywords": [
    "design-system",
    "bootstrap",
    "sass",
    "voice-aura",
    "saas",
    "ui-kit"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "bootstrap": "^5.3.8",
    "playwright": "^1.58.2",
    "sass": ">=1.98.0 <2.0.0"
  },
  "dependencies": {
    "lucide-static": "^1.0.1"
  }
}
