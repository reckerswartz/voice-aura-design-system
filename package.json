{
  "name": "voice-aura-design-system",
  "version": "1.0.0",
  "description": "A premium SaaS design system built on Bootstrap 5, inspired by the Voice Aura AI platform",
  "main": "dist/css/voice-aura.css",
  "style": "dist/css/voice-aura.css",
  "sass": "scss/voice-aura.scss",
  "exports": {
    ".": "./dist/css/voice-aura.css",
    "./css": "./dist/css/voice-aura.css",
    "./css/min": "./dist/css/voice-aura.min.css",
    "./scss": "./scss/voice-aura.scss",
    "./scss/*": "./scss/*",
    "./assets/*": "./assets/*",
    "./tokens/css": "./dist/tokens/tokens.css",
    "./tokens/scss": "./dist/tokens/_tokens.scss",
    "./tokens/json": "./dist/tokens/tokens.json"
  },
  "files": [
    "dist/css/",
    "dist/tokens/",
    "tokens/",
    "scss/",
    "assets/brand/",
    "assets/icons/",
    "assets/illustrations/",
    "assets/images/",
    "assets/patterns/",
    "js/",
    "examples/",
    "bin/setup.js",
    "DESIGN_SYSTEM.md",
    "RAILS_INTEGRATION.md",
    "ASSET_GUIDELINES.md",
    "ATTRIBUTIONS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "voice-aura-setup": "bin/setup.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reckerswartz/voice-aura-design-system.git"
  },
  "homepage": "https://reckerswartz.github.io/voice-aura-design-system/",
  "bugs": {
    "url": "https://github.com/reckerswartz/voice-aura-design-system/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:css": "sass scss/voice-aura.scss dist/css/voice-aura.css --style=expanded --source-map",
    "build:min": "sass scss/voice-aura.scss dist/css/voice-aura.min.css --style=compressed --no-source-map",
    "postcss:prefix": "postcss dist/css/voice-aura.css --use autoprefixer -o dist/css/voice-aura.css --no-map",
    "postcss:min": "postcss dist/css/voice-aura.min.css --use autoprefixer cssnano -o dist/css/voice-aura.min.css --no-map",
    "build": "npm run build:css && npm run build:min && npm run postcss:prefix && npm run postcss:min",
    "build:sass": "npm run build:css && npm run build:min",
    "tokens:build": "style-dictionary build --config style-dictionary.config.js",
    "test:size": "node -e \"const s=require('fs').statSync('dist/css/voice-aura.min.css').size;const kb=Math.round(s/1024);console.log(kb+'KB minified');if(s>400000){console.error('FAIL: CSS exceeds 400KB budget ('+kb+'KB)');process.exit(1)}else{console.log('PASS: under 400KB budget')}\"",
    "watch:css": "sass --watch scss/voice-aura.scss dist/css/voice-aura.css --style=expanded --source-map",
    "lint": "stylelint \"scss/**/*.scss\"",
    "lint:fix": "stylelint \"scss/**/*.scss\" --fix",
    "optimize:svg": "svgo --config svgo.config.js -f assets/icons/ -f assets/brand/ -f assets/patterns/ -f assets/illustrations/ -f assets/images/ --recursive",
    "prepublishOnly": "npm run build",
    "preversion": "npm run build",
    "version": "npm run build && git add -A dist/",
    "postversion": "git push && git push --tags",
    "release:patch": "npm version patch -m 'Release %s'",
    "release:minor": "npm version minor -m 'Release %s'",
    "release:major": "npm version major -m 'Release %s'",
    "test:visual": "npx playwright test tests/visual.spec.js",
    "test:a11y": "npx playwright test tests/a11y.spec.js",
    "test": "npm run test:size && npm run test:a11y",
    "screenshots": "node bin/screenshot-capture.mjs",
    "screenshots:quick": "node bin/screenshot-capture.mjs --breakpoints fhd,md,xs --skip-devices --concurrency 4 --pages-parallel 3",
    "screenshots:upload": "node bin/screenshot-upload.mjs",
    "screenshots:all": "npm run screenshots && npm run screenshots:upload"
  },
  "keywords": [
    "design-system",
    "bootstrap",
    "sass",
    "scss",
    "voice-aura",
    "saas",
    "ui-kit",
    "css-framework",
    "bootstrap-theme",
    "components"
  ],
  "author": "reckerswartz",
  "license": "ISC",
  "type": "commonjs",
  "peerDependencies": {
    "bootstrap": ">=5.3.0"
  },
  "peerDependenciesMeta": {
    "bootstrap": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "autoprefixer": "^10.4.27",
    "bootstrap": "^5.3.8",
    "cssnano": "^7.1.3",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": ">=1.98.0 <2.0.0",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0"
  },
  "dependencies": {
    "lucide-static": "^1.0.1"
  }
}
